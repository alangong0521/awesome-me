[Unit]
Description=AwesomeMe browser x11vnc :99 (rfb 5901)
After=awesome-browser-session.service

[Service]
Type=simple
ExecStart=/usr/bin/x11vnc -display :99 -auth %h/.Xauthority -localhost -forever -shared -rfbport 5901 -rfbauth %h/.vnc/passwd -o %h/.vnc/x11vnc-browser.log
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
