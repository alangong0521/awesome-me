<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg"
    android:orientation="vertical">

    <!-- 机器栏：已存机器一行横排(可横滑),选中高亮;选中某台机器 → 下方标签栏只显示该机标签 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/keybar_bg"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/machines_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="4dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="@color/divider" />

    <!-- 标签栏：每个打开的会话一个标签，右端"+"新建 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/keybar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabs_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/btn_add_tab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:backgroundTint="@color/key_background"
            android:minWidth="48dp"
            android:text="+"
            android:textColor="@color/key_text"
            android:textSize="14sp" />

        <!-- 推送收件箱:文件推送记录(未读角标);点开看列表/下载 -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp">

            <Button
                android:id="@+id/btn_inbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/key_background"
                android:minWidth="48dp"
                android:text="⬇"
                android:textColor="@color/key_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/inbox_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/inbox_badge_bg"
                android:minWidth="16dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="@color/divider" />

    <!-- 状态栏：标签名 @ host:port · 连接状态 · 终端标题 -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/status_bg"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:singleLine="true"
        android:textColor="@color/status_text"
        android:textSize="12sp" />

    <!-- 终端区:包一层 FrameLayout(空态提示 + IME 动画期间冻结 TerminalView 高度用) -->
    <FrameLayout
        android:id="@+id/terminal_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.termux.view.TerminalView
            android:id="@+id/terminal_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 桌面标签(noVNC):每个"桌面"标签一个 WebView,切换时 show/hide -->
        <WebView
            android:id="@+id/desktop_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/empty_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/empty_machine_hint"
            android:textColor="@color/key_text"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 特殊键栏：最终顺序(ESC ⏎ 键盘 ↑ ↓ ← → ⌫ TAB CTRL SHIFT 横屏,共 12 键,ALT 已移除)，
         栏可横向滚动；id 供代码设置系统手势排除区(防横滑误触切换应用/返回) -->
    <HorizontalScrollView
        android:id="@+id/keybar_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@color/keybar_bg"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/key_esc"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="ESC"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_enter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="⏎"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_keyboard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="@string/key_keyboard"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_up"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="56dp"
                android:text="↑"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_down"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="56dp"
                android:text="↓"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_left"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="56dp"
                android:text="←"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_right"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="56dp"
                android:text="→"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_backspace"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="56dp"
                android:text="⌫"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_tab"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="TAB"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_ctrl"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="CTRL"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_shift"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="SHIFT"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_alt"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="ALT"
                android:textColor="@color/key_text"
                android:textSize="12sp" />
            <Button
                android:id="@+id/key_orientation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="64dp"
                android:text="@string/key_to_landscape"
                android:textColor="@color/key_text"
                android:textSize="12sp" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
