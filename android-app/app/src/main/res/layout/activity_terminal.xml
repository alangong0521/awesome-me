<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg"
    android:orientation="vertical">

    <!-- 机器栏:已存机器一行横排(可横滑),选中高亮;右端固定 + 新建标签 和 ⬇ 收件箱 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/keybar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/machines_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/btn_add_tab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:backgroundTint="@color/key_background"
            android:minWidth="48dp"
            android:text="+"
            android:textColor="@color/key_text"
            android:textSize="14sp" />

        <!-- 上传:系统文件选择器(可多选)→ POST 到服务端 ~/phone-uploads/ -->
        <Button
            android:id="@+id/btn_upload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:backgroundTint="@color/key_background"
            android:minWidth="48dp"
            android:text="⬆"
            android:textColor="@color/key_text"
            android:textSize="14sp" />

        <!-- 推送收件箱:文件推送记录(未读角标);点开看列表/下载 -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp">

            <Button
                android:id="@+id/btn_inbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/key_background"
                android:minWidth="48dp"
                android:text="⬇"
                android:textColor="@color/key_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/inbox_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/inbox_badge_bg"
                android:minWidth="16dp"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="@color/divider" />

    <!-- 标签栏：每个打开的会话一个标签(不带机器名前缀,机器由机器栏表达) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/keybar_bg"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/tabs_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="@color/divider" />

    <!-- 状态栏：标签名 @ host:port · 连接状态 · 终端标题 -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/status_bg"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:singleLine="true"
        android:textColor="@color/status_text"
        android:textSize="12sp" />

    <!-- 终端区:PanInterceptLayout(空态提示 + IME 冻结 TerminalView 高度 + 桌面标签手势分发) -->
    <com.calla.remoteterminal.PanInterceptLayout
        android:id="@+id/terminal_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.termux.view.TerminalView
            android:id="@+id/terminal_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 桌面标签(noVNC):每个"桌面"标签一个 WebView,切换时 show/hide -->
        <WebView
            android:id="@+id/desktop_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/empty_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/empty_machine_hint"
            android:textColor="@color/key_text"
            android:textSize="14sp"
            android:visibility="gone" />
    </com.calla.remoteterminal.PanInterceptLayout>

    <!-- 特殊键栏(两行):第一行 ⏎ TAB ↑ ↓ ← →(均分铺满)+ 横竖屏 Fn;
         第二行 ESC ⌫ CTRL SHIFT ALT F1 F2 键盘(均分)。容器 id 供手势排除区用 -->
    <LinearLayout
        android:id="@+id/keybar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@color/keybar_bg"
        android:orientation="vertical"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:paddingTop="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/key_enter"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="⏎"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_tab"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="TAB"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_up"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="↑"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_down"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="↓"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_left"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="←"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_right"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="→"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_orientation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="@string/key_to_landscape"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_fn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="Fn"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/key_esc"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="ESC"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_backspace"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="⌫"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_ctrl"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="CTRL"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_shift"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="SHIFT"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_alt"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="ALT"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_f1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="F1"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_f2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="F2"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
            <Button
                android:id="@+id/key_keyboard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:layout_marginHorizontal="3dp"
                android:backgroundTint="@color/key_background"
                app:cornerRadius="9dp"
                android:minWidth="0dp"
                android:paddingHorizontal="4dp"
                android:text="@string/key_keyboard"
                android:textColor="@color/key_text"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
